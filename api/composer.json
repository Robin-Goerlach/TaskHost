{
  "name": "sasd/taskhost-api",
  "description": "TaskHost API - Wunderlist-inspiriertes REST-Backend in PHP",
  "type": "project",
  "require": {
    "php": "^8.2"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "autoload": {
    "psr-4": {
      "TaskHost\\": "src/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit --configuration phpunit.xml",
    "test:unit": "vendor/bin/phpunit --testsuite Unit --configuration phpunit.xml"
  }
}
