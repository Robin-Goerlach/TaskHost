APP_ENV=dev
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin

# Public service URL of the API root. The canonical API surface is exposed below /v1.
# Example local:  http://127.0.0.1:8080
# Example IONOS:  https://api.sasd.de/taskhost
APP_URL=http://127.0.0.1:8080

# Optional override for the externally visible service path.
# Leave empty in most cases. Example: /taskhost
APP_BASE_PATH=

# Public URL of the frontend application root.
FRONTEND_APP_URL=http://127.0.0.1:4173

# Database configuration.
DB_DSN=sqlite:storage/taskhost.sqlite
DB_USER=
DB_PASSWORD=

# Relative paths are resolved against the API project root.
UPLOAD_DIR=storage/uploads
MAIL_TRANSPORT=file
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME=TaskHost
MAIL_FILE_DIR=storage/mail

TOKEN_TTL_HOURS=720
QUEUE_RETRY_BACKOFF_SECONDS=30

# Set this to the concrete client origin in production, for example:
# CORS_ALLOW_ORIGIN=https://app.sasd.de
CORS_ALLOW_ORIGIN=*
