APP_ENV=dev
APP_DEBUG=true
APP_URL=http://127.0.0.1:8080
FRONTEND_APP_URL=http://127.0.0.1:4173
APP_TIMEZONE=Europe/Berlin

DB_DSN=sqlite:/mnt/data/taskhost-api/storage/taskhost.sqlite
DB_USER=
DB_PASSWORD=

UPLOAD_DIR=/mnt/data/taskhost-api/storage/uploads
MAIL_TRANSPORT=file
MAIL_FROM_ADDRESS=no-reply@example.test
MAIL_FROM_NAME=TaskHost
MAIL_FILE_DIR=/mnt/data/taskhost-api/storage/mail

TOKEN_TTL_HOURS=720
QUEUE_RETRY_BACKOFF_SECONDS=30
CORS_ALLOW_ORIGIN=*
